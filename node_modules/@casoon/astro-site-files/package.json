{
  "name": "@casoon/astro-site-files",
  "version": "0.4.1",
  "description": "Astro integration that generates robots.txt, llms.txt, sitemap.xml, security.txt, and humans.txt at build time from typed configuration.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./rss": {
      "import": "./dist/rss.js",
      "types": "./dist/rss.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "astro",
    "astro-integration",
    "withastro",
    "robots.txt",
    "llms.txt",
    "sitemap",
    "security.txt",
    "humans.txt",
    "seo"
  ],
  "license": "MIT",
  "author": {
    "name": "Jörn Seidel",
    "url": "https://www.casoon.de",
    "email": "info@casoon.de"
  },
  "homepage": "https://github.com/casoon/astro-site-files#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/casoon/astro-site-files.git"
  },
  "bugs": {
    "url": "https://github.com/casoon/astro-site-files/issues"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "peerDependencies": {
    "astro": ">=6.0.0"
  },
  "peerDependenciesMeta": {
    "astro": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {},
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "prepublishOnly": "npm test && npm run build"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "^5.8.3",
    "vitest": "^2.0.0"
  }
}
