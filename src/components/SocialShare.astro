---
interface Props {
  title: string;
  description: string;
  image: string;
}

const { title, description, image } = Astro.props;

// Construct absolute URLs
const siteUrl = Astro.site ? Astro.site.toString() : "https://recipe-site.pages.dev/";
const shareUrl = new URL(Astro.url.pathname, siteUrl).toString();
const absoluteImageUrl = new URL(image, siteUrl).toString();

// URL Encode values for query params
const encodedUrl = encodeURIComponent(shareUrl);
const encodedTitle = encodeURIComponent(`Check out this delicious recipe: ${title}`);
const encodedDescription = encodeURIComponent(description);
const encodedImage = encodeURIComponent(absoluteImageUrl);

const pinterestLink = `https://pinterest.com/pin/create/button/?url=${encodedUrl}&media=${encodedImage}&description=${encodedDescription}`;
const facebookLink = `https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`;
const xLink = `https://twitter.com/intent/tweet?url=${encodedUrl}&text=${encodedTitle}`;
---

<div class="flex flex-wrap items-center gap-3 py-4">
  <span class="text-sm font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider mr-2">Share Recipe:</span>
  
  {/* Pinterest Button */}
  <a 
    href={pinterestLink} 
    target="_blank" 
    rel="noopener noreferrer"
    class="inline-flex items-center gap-2.5 px-4 py-2.5 rounded-xl bg-[#BD081C] hover:bg-[#a00718] text-white text-sm font-medium shadow-md shadow-red-500/10 hover:scale-[1.02] active:scale-[0.98] transition-all duration-200"
    aria-label="Share on Pinterest"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-pinterest" viewBox="0 0 16 16">
      <path d="M8 0a8 8 0 0 0-2.915 15.452c-.07-.633-.134-1.606.027-2.298.146-.625.938-3.977.938-3.977s-.239-.479-.239-1.187c0-1.113.645-1.943 1.448-1.943.682 0 1.012.512 1.012 1.127 0 .686-.437 1.712-.663 2.663-.188.796.4 1.446 1.185 1.446 1.422 0 2.515-1.5 2.515-3.664 0-1.915-1.377-3.254-3.342-3.254-2.276 0-3.612 1.707-3.612 3.471 0 .688.265 1.425.595 1.826a.24.24 0 0 1 .056.23c-.061.252-.196.796-.222.907-.035.146-.116.177-.268.107-1-.465-1.624-1.926-1.624-3.1 0-2.523 1.834-4.84 5.286-4.84 2.775 0 4.932 1.977 4.932 4.62 0 2.757-1.739 4.976-4.151 4.976-1.077 0-2.09-.56-2.437-1.22l-.663 2.532c-.24.921-.89 2.078-1.324 2.784A8 8 0 1 0 8 0"/>
    </svg>
    <span>Pinterest</span>
  </a>

  {/* Facebook Button */}
  <a 
    href={facebookLink} 
    target="_blank" 
    rel="noopener noreferrer"
    class="inline-flex items-center gap-2.5 px-4 py-2.5 rounded-xl bg-[#1877F2] hover:bg-[#125ec7] text-white text-sm font-medium shadow-md shadow-blue-500/10 hover:scale-[1.02] active:scale-[0.98] transition-all duration-200"
    aria-label="Share on Facebook"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-facebook" viewBox="0 0 16 16">
      <path d="M16 8.049c0-4.446-3.582-8.05-8-8.05C3.58 0-.002 3.603-.002 8.05c0 4.017 2.926 7.347 6.75 7.951v-5.625h-2.03V8.05H6.75V6.275c0-2.017 1.195-3.131 3.022-3.131.876 0 1.791.157 1.791.157v1.98h-1.009c-.993 0-1.303.621-1.303 1.258v1.51h2.218l-.354 2.326H9.25V16c3.824-.604 6.75-3.934 6.75-7.951"/>
    </svg>
    <span>Facebook</span>
  </a>

  {/* X (Twitter) Button */}
  <a 
    href={xLink} 
    target="_blank" 
    rel="noopener noreferrer"
    class="inline-flex items-center gap-2.5 px-4 py-2.5 rounded-xl bg-slate-900 hover:bg-black dark:bg-slate-800 dark:hover:bg-slate-700 text-white text-sm font-medium shadow-md hover:scale-[1.02] active:scale-[0.98] transition-all duration-200"
    aria-label="Share on X"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
      <path d="M12.6.75h2.454l-5.36 6.142L16 15.25h-4.937l-3.867-5.07-4.425 5.07H.316l5.733-6.57L0 .75h5.063l3.495 4.633L12.6.75Zm-.86 13.028h1.36L4.323 2.145H2.865z"/>
    </svg>
    <span>Share on X</span>
  </a>
</div>
