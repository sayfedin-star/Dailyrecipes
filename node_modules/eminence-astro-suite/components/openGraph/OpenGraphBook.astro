---
interface Props {
  /**
   * Each value renders one `book:author` tag.
   */
  authors?: string[];
  isbn?: string;
  /**
   * ISO 8601 date/time string (`YYYY-MM-DD` or `YYYY-MM-DDTHH:mm:ssZ`).
   * @example 2026-04-01
   * @example 2026-04-01T00:00:00Z
   */
  releaseDate?: string;
  /**
   * Each value renders one `book:tag` tag.
   */
  tags?: string[];
}

const { authors = [], isbn, releaseDate, tags = [] } = Astro.props;
---

{authors.map((a) => <meta property="book:author" content={a} />)}
{isbn && <meta property="book:isbn" content={isbn} />}
{releaseDate && <meta property="book:release_date" content={releaseDate} />}
{tags.map((t) => <meta property="book:tag" content={t} />)}
