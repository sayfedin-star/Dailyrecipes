---
import Layout from "../../layouts/Layout.astro";
import RecipeCard from "../../components/RecipeCard.astro";
import { getCollection } from "astro:content";
import { formatCategory } from "../../utils/category";

export async function getStaticPaths() {
  const recipes = await getCollection("recipes");
  const categories = [...new Set(recipes.map((r) => r.data.category.toLowerCase()))];
  
  return categories.map((category) => {
    const filteredRecipes = recipes.filter(
      (r) => r.data.category.toLowerCase() === category
    );
    
    // Retrieve original capitalized name of category
    const originalCategoryName = recipes.find(
      (r) => r.data.category.toLowerCase() === category
    )?.data.category || category;

    return {
      params: { slug: category },
      props: { 
        category: formatCategory(originalCategoryName),
        recipes: filteredRecipes 
      },
    };
  });
}

const { category, recipes } = Astro.props;
---

<Layout title={`${category} Recipes`} description={`Browse all our delicious ${category.toLowerCase()} recipes.`}>
  {/* Category Hero */}
  <section class="py-12 border-b border-slate-200/50 dark:border-slate-800/60 mb-10">
    <div class="flex items-center gap-2 text-xs font-semibold text-slate-400 mb-3 uppercase tracking-wider">
      <a href="/" class="hover:text-amber-500 transition-colors">Home</a>
      <span>/</span>
      <span class="text-slate-500 dark:text-slate-350">{category}</span>
    </div>
    <h1 class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-slate-900 dark:text-white">
      {category} Recipes
    </h1>
    <p class="text-slate-600 dark:text-slate-300 mt-3 max-w-xl">
      Discover delicious and easy-to-cook {category.toLowerCase()} recipes to delight your family and friends.
    </p>
  </section>

  {/* Recipes Grid */}
  <section>
    {recipes.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {recipes.map((recipe) => (
          <RecipeCard 
            slug={recipe.id} 
            title={recipe.data.title} 
            image={recipe.data.image} 
            prepTime={recipe.data.prepTime} 
            category={recipe.data.category} 
          />
        ))}
      </div>
    ) : (
      <div class="text-center py-16">
        <p class="text-slate-500 dark:text-slate-400">No recipes found in this category.</p>
        <a href="/" class="inline-block mt-4 text-amber-500 hover:text-amber-600 font-medium">Back to Homepage</a>
      </div>
    )}
  </section>
</Layout>
