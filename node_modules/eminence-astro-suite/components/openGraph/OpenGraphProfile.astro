---
interface Props {
  firstName?: string;
  lastName?: string;
  /**
   * Public profile handle emitted as `profile:username`.
   */
  username?: string;
  /**
   * Free-form gender value emitted as-is.
   */
  gender?: string;
}

const { firstName, lastName, username, gender } = Astro.props;
---

{firstName && <meta property="profile:first_name" content={firstName} />}
{lastName && <meta property="profile:last_name" content={lastName} />}
{username && <meta property="profile:username" content={username} />}
{gender && <meta property="profile:gender" content={gender} />}
