---
import Layout from "../../layouts/Layout.astro";
import SocialShare from "../../components/SocialShare.astro";
import SchemaScript from "@rafters/astro-meta/components/SchemaScript.astro";
import { getCollection, render } from "astro:content";
import { Picture } from "astro:assets";

export async function getStaticPaths() {
  const recipes = await getCollection("recipes");
  return recipes.map((recipe) => ({
    params: { slug: recipe.id },
    props: { recipe },
  }));
}

const { recipe } = Astro.props;
let Content = null;
try {
  const rendered = await render(recipe);
  Content = rendered.Content;
} catch (e) {
  // JSON files do not have a markdown renderer
}

const {
  title,
  date,
  description,
  image,
  prepTime,
  cookTime,
  servings,
  calories,
  category,
  tags,
  ingredients,
  steps,
  jumpToRecipeUrl,
} = recipe.data;

// Formatting Date
const formattedDate = new Date(date).toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

// Constructing Schema.org JSON-LD structured data
const siteUrl = Astro.site ? Astro.site.toString() : "https://recipe-site.pages.dev/";
const absoluteImageUrl = new URL(image.src, siteUrl).toString();
const absoluteUrl = new URL(Astro.url.pathname, siteUrl).toString();

const recipeSchema = {
  "@context": "https://schema.org",
  "@type": "Recipe",
  "name": title,
  "description": description,
  "image": absoluteImageUrl,
  "datePublished": date.toISOString().split('T')[0],
  "prepTime": `PT${prepTime}M`,
  "cookTime": `PT${cookTime}M`,
  "recipeYield": `${servings} servings`,
  "recipeCategory": category,
  "recipeCuisine": "International",
  "keywords": tags.join(", "),
  "nutrition": {
    "@type": "NutritionInformation",
    "calories": `${calories} calories`
  },
  "recipeIngredient": ingredients,
  "recipeInstructions": steps.map((step, index) => ({
    "@type": "HowToStep",
    "text": step,
    "position": index + 1
  }))
};
---

<Layout title={title} description={description} image={image.src}>
  {/* JSON-LD Structured Data for Google search crawlers */}
  <SchemaScript graph={recipeSchema} />

  <article class="max-w-4xl mx-auto">
    {/* Category & Date */}
    <div class="flex items-center gap-3 mb-4">
      <span class="px-3 py-1 rounded-lg bg-amber-100 dark:bg-amber-950/40 text-amber-800 dark:text-amber-300 text-xs font-bold uppercase tracking-wider">
        {category}
      </span>
      <time datetime={date.toISOString()} class="text-xs font-semibold text-slate-400">
        Published: {formattedDate}
      </time>
    </div>

    {/* Title & Description */}
    <h1 class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-slate-900 dark:text-white leading-tight mb-4">
      {title}
    </h1>
    <p class="text-lg text-slate-600 dark:text-slate-300 leading-relaxed mb-6">
      {description}
    </p>

    {/* Jump & Share bar */}
    <div class="flex flex-col sm:flex-row sm:items-center justify-between border-y border-slate-200/60 dark:border-slate-800/60 py-3 mb-8 gap-4">
      <a 
        href={jumpToRecipeUrl || "#recipe-card"} 
        target={jumpToRecipeUrl ? "_blank" : undefined}
        rel={jumpToRecipeUrl ? "noopener noreferrer" : undefined}
        class="inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-xl bg-amber-500 hover:bg-amber-600 active:scale-98 text-white font-semibold text-sm shadow-md shadow-amber-500/15 transition-all"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
          <path fill-rule="evenodd" d="M1 8a.5.5 0 0 1 .5-.5h11.793l-3.147-3.146a.5.5 0 0 1 .708-.708l4 4a.5.5 0 0 1 0 .708l-4 4a.5.5 0 0 1-.708-.708L13.293 8.5H1.5A.5.5 0 0 1 1 8"/>
        </svg>
        <span>Jump to Recipe</span>
      </a>
      
      <SocialShare title={title} description={description} image={image.src} />
    </div>

    {/* Large Hero Image */}
    <div class="relative w-full aspect-[16/9] rounded-3xl overflow-hidden bg-slate-100 dark:bg-slate-850 shadow-lg border border-slate-200/30 dark:border-slate-800/35 mb-10">
      <Picture 
        src={image} 
        alt={title}
        widths={[400, 800, 960, 1200]}
        sizes="(max-width: 640px) 100vw, (max-width: 1024px) 800px, 960px"
        formats={['avif', 'webp']}
        fallbackFormat="webp"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        class="object-cover w-full h-full"
      />
    </div>

    {/* Recipe Card (Jump anchor target) */}
    <section 
      id="recipe-card" 
      class="scroll-mt-20 border border-amber-200/60 dark:border-amber-900/40 bg-amber-50/35 dark:bg-slate-900/40 rounded-3xl p-6 sm:p-8 mb-12"
    >
      <div class="text-center sm:text-left mb-6 border-b border-amber-200/50 dark:border-slate-800/60 pb-4">
        <h2 class="text-2xl font-bold text-slate-800 dark:text-white">Recipe Details</h2>
        <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">Quick summary of cook times and nutrition</p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        <div class="p-4 bg-white dark:bg-slate-900/80 rounded-2xl border border-slate-100 dark:border-slate-800/40 shadow-sm">
          <span class="block text-xs font-semibold text-slate-400 uppercase tracking-wider">Prep Time</span>
          <span class="block text-xl font-extrabold text-slate-800 dark:text-white mt-1">{prepTime} mins</span>
        </div>
        <div class="p-4 bg-white dark:bg-slate-900/80 rounded-2xl border border-slate-100 dark:border-slate-800/40 shadow-sm">
          <span class="block text-xs font-semibold text-slate-400 uppercase tracking-wider">Cook Time</span>
          <span class="block text-xl font-extrabold text-slate-800 dark:text-white mt-1">{cookTime} mins</span>
        </div>
        <div class="p-4 bg-white dark:bg-slate-900/80 rounded-2xl border border-slate-100 dark:border-slate-800/40 shadow-sm">
          <span class="block text-xs font-semibold text-slate-400 uppercase tracking-wider">Servings</span>
          <span class="block text-xl font-extrabold text-slate-800 dark:text-white mt-1">{servings}</span>
        </div>
        <div class="p-4 bg-white dark:bg-slate-900/80 rounded-2xl border border-slate-100 dark:border-slate-800/40 shadow-sm">
          <span class="block text-xs font-semibold text-slate-400 uppercase tracking-wider">Calories</span>
          <span class="block text-xl font-extrabold text-slate-800 dark:text-white mt-1">{calories} kcal</span>
        </div>
      </div>
    </section>

    {/* Ingredients & Steps Layout */}
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-10">
      {/* Left Column: Ingredients (2/5 size) */}
      <section class="lg:col-span-2">
        <h3 class="text-xl font-extrabold text-slate-900 dark:text-white mb-5 flex items-center gap-2">
          Ingredients
        </h3>
        <ul class="space-y-3">
          {ingredients.map((ingredient) => (
            <li class="flex items-start gap-3 text-slate-700 dark:text-slate-300">
              <span class="flex-shrink-0 w-5 h-5 rounded border border-slate-300 dark:border-slate-700 flex items-center justify-center mt-0.5 bg-white dark:bg-slate-900">
              </span>
              <span class="text-sm font-medium leading-relaxed">{ingredient}</span>
            </li>
          ))}
        </ul>
      </section>

      {/* Right Column: Instructions (3/5 size) */}
      <section class="lg:col-span-3">
        <h3 class="text-xl font-extrabold text-slate-900 dark:text-white mb-5">
          Instructions
        </h3>
        <ol class="space-y-6">
          {steps.map((step, index) => (
            <li class="flex gap-4">
              <span class="flex-shrink-0 w-8 h-8 rounded-full bg-gradient-to-br from-amber-500 to-rose-500 flex items-center justify-center text-white font-extrabold text-sm shadow-md">
                {index + 1}
              </span>
              <div class="pt-1">
                <p class="text-sm text-slate-700 dark:text-slate-300 leading-relaxed font-medium">
                  {step}
                </p>
              </div>
            </li>
          ))}
        </ol>
      </section>
    </div>

    {/* Markdown or JSON Body Content Render */}
    {Content ? (
      <div class="prose prose-slate dark:prose-invert max-w-none mt-16 pt-8 border-t border-slate-200/60 dark:border-slate-800/60 text-slate-600 dark:text-slate-350">
        <Content />
      </div>
    ) : recipe.data.body ? (
      <div class="prose prose-slate dark:prose-invert max-w-none mt-16 pt-8 border-t border-slate-200/60 dark:border-slate-800/60 text-slate-600 dark:text-slate-350">
        <p>{recipe.data.body}</p>
      </div>
    ) : null}

    {/* Tags */}
    <div class="flex flex-wrap gap-2 mt-10">
      {tags.map((tag) => (
        <span class="px-3 py-1 rounded-lg bg-slate-100 dark:bg-slate-900 text-slate-600 dark:text-slate-400 text-xs font-semibold">
          #{tag}
        </span>
      ))}
    </div>
  </article>
</Layout>
