{
  "name": "@rafters/astro-meta",
  "version": "0.2.0",
  "description": "Build-time artifacts for crawlers and LLMs on Astro 6: JSON-LD, llms.txt, robots, sitemap, OG images, and build-time GEO readability scoring. Composes with @rafters/astro-data.",
  "keywords": [
    "aeo",
    "astro",
    "astro-component",
    "astro-integration",
    "geo",
    "json-ld",
    "llms-txt",
    "rafters",
    "robots",
    "schema-org",
    "seo",
    "sitemap",
    "withastro"
  ],
  "homepage": "https://github.com/rafters-studio/astro-meta#readme",
  "bugs": {
    "url": "https://github.com/rafters-studio/astro-meta/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rafters-studio/astro-meta.git"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./astro": {
      "types": "./dist/astro.d.ts",
      "import": "./dist/astro.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "import": "./dist/schema.js"
    },
    "./entities": {
      "types": "./dist/entities.d.ts",
      "import": "./dist/entities.js"
    },
    "./llms-txt": {
      "types": "./dist/llms-txt.d.ts",
      "import": "./dist/llms-txt.js"
    },
    "./robots": {
      "types": "./dist/robots.d.ts",
      "import": "./dist/robots.js"
    },
    "./sitemap": {
      "types": "./dist/sitemap.d.ts",
      "import": "./dist/sitemap.js"
    },
    "./og": {
      "types": "./dist/og.d.ts",
      "import": "./dist/og.js"
    },
    "./audit": {
      "types": "./dist/audit.d.ts",
      "import": "./dist/audit.js"
    },
    "./components/SiteMeta.astro": "./dist/components/SiteMeta.astro",
    "./components/SchemaScript.astro": "./dist/components/SchemaScript.astro",
    "./components/OgImage.astro": "./dist/components/OgImage.astro"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && mkdir -p dist/components && cp src/components/*.astro dist/components/",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test": "vitest run",
    "test:spec": "vitest run --config vitest.browser.config.ts",
    "test:all": "pnpm test && pnpm test:spec",
    "verify": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm test"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^22.10.0",
    "@vitest/browser": "^4.1.0",
    "astro": "^6.1.9",
    "lefthook": "^2.1.4",
    "linkedom": "^0.18.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "playwright": "^1.49.0",
    "satori": "^0.13.0",
    "schema-dts": "^1.1.5",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "@resvg/resvg-js": "^2.6.0",
    "astro": "^6.0.0",
    "linkedom": "^0.18.0",
    "satori": "^0.13.0",
    "schema-dts": "^1.1.0"
  },
  "peerDependenciesMeta": {
    "@resvg/resvg-js": {
      "optional": true
    },
    "linkedom": {
      "optional": true
    },
    "satori": {
      "optional": true
    },
    "schema-dts": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.32.1"
}
