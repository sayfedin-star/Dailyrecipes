---
import Layout from "../../layouts/Layout.astro";
import SocialShare from "../../components/SocialShare.astro";
import SchemaScript from "@rafters/astro-meta/components/SchemaScript.astro";
import { getCollection, render } from "astro:content";
import { Picture, Image } from "astro:assets";
import authorAvatar from "../../assets/images/author-avatar.png";

export async function getStaticPaths() {
  const recipes = await getCollection("recipes");
  return recipes.map((recipe) => ({
    params: { slug: recipe.id },
    props: { recipe },
  }));
}

const { recipe } = Astro.props;
let Content = null;
try {
  const rendered = await render(recipe);
  Content = rendered.Content;
} catch (e) {
  // JSON files do not have a markdown renderer
}

const {
  title,
  date,
  description,
  image,
  prepTime,
  cookTime,
  servings,
  calories,
  category,
  tags,
  ingredients,
  steps,
  jumpToRecipeUrl,
} = recipe.data;

// Formatting Date
const formattedDate = new Date(date).toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

// Constructing Schema.org JSON-LD structured data
const siteUrl = Astro.site ? Astro.site.toString() : "https://recipe-site.pages.dev/";
const imageUrl = typeof image === 'string' ? image : image.src;
const absoluteImageUrl = typeof image === 'string' ? image : new URL(image.src, siteUrl).toString();
const absoluteUrl = new URL(Astro.url.pathname, siteUrl).toString();

const recipeSchema = {
  "@context": "https://schema.org",
  "@type": "Recipe",
  "name": title,
  "description": description,
  "image": absoluteImageUrl,
  "datePublished": date.toISOString().split('T')[0],
  "prepTime": `PT${prepTime}M`,
  "cookTime": `PT${cookTime}M`,
  "recipeYield": `${servings} servings`,
  "recipeCategory": category,
  "recipeCuisine": "International",
  "keywords": tags.join(", "),
  "nutrition": {
    "@type": "NutritionInformation",
    "calories": `${calories} calories`
  },
  "recipeIngredient": ingredients,
  "recipeInstructions": steps.map((step, index) => ({
    "@type": "HowToStep",
    "text": step,
    "position": index + 1
  }))
};

// URL encode variables for social share
const encodedUrl = encodeURIComponent(absoluteUrl);
const encodedImage = encodeURIComponent(absoluteImageUrl);
const encodedDescription = encodeURIComponent(description);
---

<Layout title={title} description={description} image={imageUrl}>
  {/* JSON-LD Structured Data for Google search crawlers */}
  <SchemaScript graph={recipeSchema} />

  {/* Outer container to establish the soft cream background of 40aprons in light mode */}
  <div class="-mx-4 sm:-mx-6 lg:-mx-8 px-4 sm:px-6 lg:px-8 -my-8 py-8 md:py-12 bg-[#FCFBF9] dark:bg-[#0c101b] min-h-screen text-slate-800 dark:text-slate-100 transition-colors duration-300">
    <article class="max-w-3xl mx-auto animate-fade-in">
      
      {/* 1. Breadcrumbs Path */}
      <nav class="flex items-center gap-1.5 text-[10px] font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest mb-3" aria-label="Breadcrumb">
        <a href="/" class="hover:text-amber-600 transition-colors">Home</a>
        <span class="text-slate-300 dark:text-slate-700">/</span>
        <a href={`/category/${category.toLowerCase()}`} class="hover:text-amber-600 transition-colors">{category}</a>
        <span class="text-slate-300 dark:text-slate-700">/</span>
      </nav>

      {/* 2. Star Rating counter */}
      <div class="flex items-center gap-1.5 mb-3">
        <div class="flex text-[#D1A153] text-lg font-serif">
          ★<span>★</span>★<span>★</span>★
        </div>
        <span class="text-xs font-semibold text-slate-500 dark:text-slate-400 tracking-wide font-sans">
          5 from 1 vote
        </span>
      </div>

      {/* 3. Serif Title Typography */}
      <h1 class="text-3xl sm:text-4xl md:text-[40px] font-serif font-medium text-slate-900 dark:text-white leading-tight mb-4 tracking-tight">
        {title}
      </h1>

      {/* 4. Author Info Section */}
      <div class="flex items-center gap-3.5 mb-5 border-b border-slate-200/60 dark:border-slate-800/60 pb-5">
        <Image 
          src={authorAvatar} 
          alt="Cheryl Malik" 
          width={44}
          height={44}
          loading="eager"
          class="w-11 h-11 rounded-full object-cover border border-slate-200/80 dark:border-slate-800 shadow-sm"
        />
        <div class="text-[11px] font-sans text-slate-500 dark:text-slate-400 leading-normal">
          <div class="font-bold text-slate-700 dark:text-slate-300 uppercase tracking-wider">
            Recipe By <span class="text-amber-600 dark:text-amber-500 hover:underline cursor-pointer">Cheryl Malik</span>
          </div>
          <div class="mt-0.5 font-medium flex flex-wrap items-center gap-x-2">
            <span>Updated {formattedDate}</span>
            <span class="text-slate-300 dark:text-slate-700">|</span>
            <span class="hover:text-amber-600 transition-colors cursor-pointer">5 Comments</span>
          </div>
        </div>
      </div>

      {/* 5. 40aprons style Actions Row */}
      <div class="flex items-center gap-3 mb-5">
        <a 
          href={jumpToRecipeUrl || "#recipe-card"} 
          target={jumpToRecipeUrl ? "_blank" : undefined}
          rel={jumpToRecipeUrl ? "noopener noreferrer" : undefined}
          class="inline-flex items-center justify-center gap-1.5 px-5 py-2 border border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-900 text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-850 hover:border-slate-400 active:scale-[0.98] font-bold text-[11px] tracking-widest uppercase transition-all duration-200 shadow-sm"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" class="animate-bounce mt-0.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
          </svg>
          <span>Jump to Recipe</span>
        </a>

        {/* Save Star Button */}
        <button 
          aria-label="Save Recipe"
          class="inline-flex items-center justify-center w-[36px] h-[36px] border border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-900 text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-850 hover:text-amber-600 hover:border-slate-400 active:scale-[0.98] transition-all duration-200 shadow-sm"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499c.15-.427.77-.427.92 0l1.598 4.54a1 1 0 00.95.69h4.907c.461 0 .65.592.272.85l-3.97 2.883a1 1 0 00-.36 1.118l1.599 4.54c.15.427-.333.782-.705.534l-3.97-2.884a1 1 0 00-1.17 0l-3.97 2.884c-.372.248-.855-.107-.705-.534l1.599-4.54a1 1 0 00-.36-1.118L2.012 9.579c-.378-.258-.189-.85.272-.85h4.907a1 1 0 00.95-.69l1.598-4.54z" />
          </svg>
        </button>

        {/* Pinterest Pin Button */}
        <a 
          href={`https://pinterest.com/pin/create/button/?url=${encodedUrl}&media=${encodedImage}&description=${encodedDescription}`}
          target="_blank" 
          rel="noopener noreferrer"
          aria-label="Pin on Pinterest"
          class="inline-flex items-center justify-center w-[36px] h-[36px] border border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-900 text-[#BD081C] hover:bg-red-50 dark:hover:bg-red-950/20 hover:border-slate-400 active:scale-[0.98] transition-all duration-200 shadow-sm"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-pinterest" viewBox="0 0 16 16">
            <path d="M8 0a8 8 0 0 0-2.915 15.452c-.07-.633-.134-1.606.027-2.298.146-.625.938-3.977.938-3.977s-.239-.479-.239-1.187c0-1.113.645-1.943 1.448-1.943.682 0 1.012.512 1.012 1.127 0 .686-.437 1.712-.663 2.663-.188.796.4 1.446 1.185 1.446 1.422 0 2.515-1.5 2.515-3.664 0-1.915-1.377-3.254-3.342-3.254-2.276 0-3.612 1.707-3.612 3.471 0 .688.265 1.425.595 1.826a.24.24 0 0 1 .056.23c-.061.252-.196.796-.222.907-.035.146-.116.177-.268.107-1-.465-1.624-1.926-1.624-3.1 0-2.523 1.834-4.84 5.286-4.84 2.775 0 4.932 1.977 4.932 4.62 0 2.757-1.739 4.976-4.151 4.976-1.077 0-2.09-.56-2.437-1.22l-.663 2.532c-.24.921-.89 2.078-1.324 2.784A8 8 0 1 0 8 0"/>
          </svg>
        </a>
      </div>

      {/* 6. Affiliate Disclosure notice */}
      <div class="border-y border-slate-200/50 dark:border-slate-800/40 py-2 mb-6 text-[10px] font-sans font-medium text-slate-400 dark:text-slate-500 italic leading-relaxed">
        This Post May Contain Affiliate Links. Please Read Our <span class="underline hover:text-slate-600 dark:hover:text-slate-350 cursor-pointer">Disclosure Policy</span>.
      </div>

      {/* 7. Description */}
      <p class="text-base sm:text-lg text-slate-600 dark:text-slate-300 leading-relaxed mb-6 font-sans">
        {description}
      </p>

      {/* Large Hero Image */}
      <div class="relative w-full aspect-[16/9] rounded-3xl overflow-hidden bg-slate-100 dark:bg-slate-850 shadow-lg border border-slate-200/30 dark:border-slate-800/35 mb-10">
        {jumpToRecipeUrl ? (
          <a 
            href={jumpToRecipeUrl} 
            target="_blank" 
            rel="noopener noreferrer" 
            class="block w-full h-full cursor-pointer hover:opacity-95 transition-opacity"
            aria-label={`Jump to external recipe for ${title}`}
          >
            {typeof image === 'string' ? (
              <img 
                src={image} 
                alt={title}
                loading="eager"
                fetchpriority="high"
                decoding="async"
                class="object-cover w-full h-full"
              />
            ) : (
              <Picture 
                src={image} 
                alt={title}
                widths={[360, 540, 720, 896]}
                sizes="(max-width: 640px) calc(100vw - 32px), (max-width: 1024px) 720px, 896px"
                quality={65}
                formats={['avif', 'webp']}
                fallbackFormat="webp"
                loading="eager"
                fetchpriority="high"
                decoding="async"
                class="object-cover w-full h-full"
              />
            )}
          </a>
        ) : (
          typeof image === 'string' ? (
            <img 
              src={image} 
              alt={title}
              loading="eager"
              fetchpriority="high"
              decoding="async"
              class="object-cover w-full h-full"
            />
          ) : (
            <Picture 
              src={image} 
              alt={title}
              widths={[360, 540, 720, 896]}
              sizes="(max-width: 640px) calc(100vw - 32px), (max-width: 1024px) 720px, 896px"
              quality={65}
              formats={['avif', 'webp']}
              fallbackFormat="webp"
              loading="eager"
              fetchpriority="high"
              decoding="async"
              class="object-cover w-full h-full"
            />
          )
        )}
      </div>

      {/* Recipe Card (Jump anchor target) */}
      <section 
        id="recipe-card" 
        class="scroll-mt-20 border border-amber-200/50 dark:border-amber-900/30 bg-amber-50/20 dark:bg-slate-900/30 rounded-3xl p-6 sm:p-8 mb-12 shadow-sm"
      >
        <div class="text-center sm:text-left mb-6 border-b border-amber-200/40 dark:border-slate-800/40 pb-4">
          <h2 class="text-2xl font-serif font-bold text-slate-800 dark:text-white">Recipe Details</h2>
          <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">Quick summary of cook times and nutrition</p>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
          <div class="p-4 bg-white dark:bg-slate-900/60 rounded-2xl border border-slate-100 dark:border-slate-800/30 shadow-xs">
            <span class="block text-xs font-semibold text-slate-400 uppercase tracking-wider">Prep Time</span>
            <span class="block text-xl font-extrabold text-slate-800 dark:text-white mt-1">{prepTime} mins</span>
          </div>
          <div class="p-4 bg-white dark:bg-slate-900/60 rounded-2xl border border-slate-100 dark:border-slate-800/30 shadow-xs">
            <span class="block text-xs font-semibold text-slate-400 uppercase tracking-wider">Cook Time</span>
            <span class="block text-xl font-extrabold text-slate-800 dark:text-white mt-1">{cookTime} mins</span>
          </div>
          <div class="p-4 bg-white dark:bg-slate-900/60 rounded-2xl border border-slate-100 dark:border-slate-800/30 shadow-xs">
            <span class="block text-xs font-semibold text-slate-400 uppercase tracking-wider">Servings</span>
            <span class="block text-xl font-extrabold text-slate-800 dark:text-white mt-1">{servings}</span>
          </div>
          <div class="p-4 bg-white dark:bg-slate-900/60 rounded-2xl border border-slate-100 dark:border-slate-800/30 shadow-xs">
            <span class="block text-xs font-semibold text-slate-400 uppercase tracking-wider">Calories</span>
            <span class="block text-xl font-extrabold text-slate-800 dark:text-white mt-1">{calories} kcal</span>
          </div>
        </div>
      </section>

      {/* Ingredients & Steps Layout */}
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-10">
        {/* Left Column: Ingredients (2/5 size) */}
        <section class="lg:col-span-2">
          <h3 class="text-xl font-serif font-bold text-slate-900 dark:text-white mb-5 flex items-center gap-2">
            Ingredients
          </h3>
          <ul class="space-y-3.5">
            {ingredients.map((ingredient) => (
              <li class="flex items-start gap-3.5 text-slate-700 dark:text-slate-355">
                <span class="flex-shrink-0 w-5 h-5 rounded-full border border-slate-300 dark:border-slate-750 flex items-center justify-center mt-0.5 bg-white dark:bg-slate-900 hover:border-amber-500 cursor-pointer transition-colors shadow-2xs">
                </span>
                <span class="text-sm font-medium leading-relaxed">{ingredient}</span>
              </li>
            ))}
          </ul>
        </section>

        {/* Right Column: Instructions (3/5 size) */}
        <section class="lg:col-span-3">
          <h3 class="text-xl font-serif font-bold text-slate-900 dark:text-white mb-5">
            Instructions
          </h3>
          <ol class="space-y-6">
            {steps.map((step, index) => (
              <li class="flex gap-4">
                <span class="flex-shrink-0 w-7 h-7 rounded-full bg-slate-200 dark:bg-slate-800 text-slate-700 dark:text-slate-300 flex items-center justify-center font-bold text-[13px] shadow-sm">
                  {index + 1}
                </span>
                <div class="pt-0.5">
                  <p class="text-sm text-slate-700 dark:text-slate-355 leading-relaxed font-medium">
                    {step}
                  </p>
                </div>
              </li>
            ))}
          </ol>
        </section>
      </div>

      {/* Markdown or JSON Body Content Render */}
      {Content ? (
        <div class="prose prose-slate dark:prose-invert max-w-none mt-16 pt-8 border-t border-slate-200/60 dark:border-slate-800/60 text-slate-600 dark:text-slate-350">
          <Content />
        </div>
      ) : recipe.data.body ? (
        <div class="prose prose-slate dark:prose-invert max-w-none mt-16 pt-8 border-t border-slate-200/60 dark:border-slate-800/60 text-slate-600 dark:text-slate-350">
          <p>{recipe.data.body}</p>
        </div>
      ) : null}

      {/* Social Share Buttons */}
      <div class="mt-12 pt-6 border-t border-slate-200/50 dark:border-slate-800/40">
        <SocialShare title={title} description={description} image={imageUrl} />
      </div>

      {/* Tags */}
      <div class="flex flex-wrap gap-2 mt-8">
        {tags.map((tag) => (
          <span class="px-3 py-1 rounded-lg bg-slate-200/60 dark:bg-slate-900 text-slate-600 dark:text-slate-400 text-xs font-semibold">
            #{tag}
          </span>
        ))}
      </div>
    </article>
  </div>
</Layout>
