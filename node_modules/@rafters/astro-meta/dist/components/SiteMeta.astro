---
// @rafters/astro-meta/components/SiteMeta.astro
//
// Site-level head fragment: generator, canonical URL, Open Graph core,
// Twitter card, description, image, article timestamps, locale. Drop into a
// layout's <head>; the `site` prop defaults to the SiteIdentity configured in
// astroMeta({ site }) via the virtual:astro-meta/site module.
//
// The tag rendering is the pure renderSiteMeta() so the component and its unit
// tests share one implementation; the component only resolves defaults.

import type { SiteIdentity } from "../index.js";
import { renderSiteMeta } from "../internal/render-site-meta.js";
import type { SiteMetaOptions } from "../internal/render-site-meta.js";
import { site as defaultSite } from "virtual:astro-meta/site";

export interface Props extends SiteMetaOptions {
  /** Override the integration-configured SiteIdentity. */
  site?: SiteIdentity;
  /** Route for canonical and og:url. Defaults to Astro.url.pathname. */
  route?: string;
}

const {
  site = defaultSite,
  route = Astro.url.pathname,
  title,
  description,
  ogType,
  publishedTime,
  modifiedTime,
  image,
} = Astro.props;

const html = renderSiteMeta(site, route, { title, description, ogType, publishedTime, modifiedTime, image });
---

<Fragment set:html={html} />
