---
import Layout from "../layouts/Layout.astro";
import RecipeCard from "../components/RecipeCard.astro";
import { getCollection } from "astro:content";
import { formatCategory } from "../utils/category";

const recipes = await getCollection("recipes");

// Sort recipes by date descending
const sortedRecipes = recipes.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

// Unique categories
const categories = [...new Set(recipes.map((r) => formatCategory(r.data.category)))];
---

<Layout title="Home" description="Explore delicious recipes on RecipeSuite. Built with Astro 6.4.">
  {/* Hero Section */}
  <section class="relative py-16 px-6 sm:py-24 rounded-3xl overflow-hidden bg-gradient-to-br from-amber-50 to-rose-50 dark:from-slate-900/60 dark:to-slate-900/40 border border-amber-100/50 dark:border-slate-800/60 mb-12">
    <div class="relative max-w-3xl mx-auto text-center">
      <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-amber-100 dark:bg-amber-950/40 text-amber-800 dark:text-amber-300 text-xs font-semibold uppercase tracking-wider mb-6">
        ✨ Freshly Baked & Cooked
      </span>
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold tracking-tight text-slate-900 dark:text-white leading-tight">
        Cook Like a <span class="bg-gradient-to-r from-amber-600 to-rose-600 dark:from-amber-400 dark:to-rose-400 bg-clip-text text-transparent">Professional</span> at Home
      </h1>
      <p class="mt-6 text-lg text-slate-600 dark:text-slate-300 max-w-xl mx-auto leading-relaxed">
        Discover easy-to-follow, delicious recipes developed by experts. Level up your cooking game today.
      </p>
    </div>
  </section>

  {/* Category Filter Pills */}
  <section class="mb-10">
    <h2 class="text-xl font-bold text-slate-900 dark:text-white mb-5 flex items-center gap-2">
      Browse by Category
    </h2>
    <div class="flex flex-wrap gap-3">
      <a 
        href="/" 
        class="px-5 py-2.5 rounded-xl border border-amber-500 bg-amber-500 text-white font-medium text-sm shadow-sm transition-all duration-200"
      >
        All Recipes
      </a>
      {categories.map((category) => (
        <a 
          href={`/category/${category.toLowerCase()}`} 
          class="px-5 py-2.5 rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 hover:border-amber-500 dark:hover:border-amber-400 text-slate-700 dark:text-slate-300 hover:text-amber-600 dark:hover:text-amber-400 font-medium text-sm transition-all duration-200"
        >
          {category}s
        </a>
      ))}
    </div>
  </section>

  {/* Recipes Grid */}
  <section>
    <h2 class="text-2xl font-extrabold text-slate-900 dark:text-white mb-6">
      Latest Recipes
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {sortedRecipes.map((recipe) => (
        <RecipeCard 
          slug={recipe.id} 
          title={recipe.data.title} 
          image={recipe.data.image} 
          prepTime={recipe.data.prepTime} 
          category={recipe.data.category} 
        />
      ))}
    </div>
  </section>
</Layout>
